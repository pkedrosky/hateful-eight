{{!< default}}

{{#page}}
  <article class="post ghost-content prose md:prose-lg prose-theme">
    <h1>Hateful Eight <span style="color:{{@site.accent_color}}">Interactive</span></h1>
    <p>Weekly rolling return vs estimated S&P 500 point contribution for the Mag 7 plus Oracle.</p>
  </article>

  {{#if access}}
    <div style="width:100%; max-width:1280px; margin:0 auto;">
      <iframe
        id="hateful-eight-frame"
        src="/tools/hateful-eight/app/"
        style="display:block;width:100%;height:980px;border:0;overflow:hidden;"
        scrolling="no"
        loading="lazy"
      ></iframe>
    </div>
  {{else}}
    <article class="post ghost-content prose md:prose-lg prose-theme">
      {{> pro-cta}}
    </article>
  {{/if}}
{{/page}}
