{{!< default}}

{{#page}}
  <article class="post ghost-content prose md:prose-lg prose-theme">
    <h1>Hateful Eight <span style="color:{{@site.accent_color}}">Interactive</span></h1>
    <p>Weekly rolling return vs estimated S&P 500 point contribution for the Mag 7 plus Oracle.</p>
  </article>

  {{#if access}}
    <div style="width:100%; max-width:1280px; margin:0 auto;">
      <iframe
        id="hateful-eight-frame"
        src="/tools/hateful-eight/app/"
        style="display:block;width:100%;height:1320px;border:0;overflow:hidden;"
        scrolling="no"
        loading="lazy"
      ></iframe>
    </div>
    <script>
      (() => {
        const iframe = document.getElementById("hateful-eight-frame");
        if (!iframe) return;

        const minHeight = 1320;
        let resizeTimer = null;

        const setHeight = (height) => {
          if (!Number.isFinite(height)) return;
          iframe.style.height = `${Math.max(minHeight, Math.ceil(height) + 20)}px`;
        };

        const measureFromIframe = () => {
          try {
            const doc = iframe.contentDocument || iframe.contentWindow?.document;
            if (!doc) return null;
            const body = doc.body;
            const html = doc.documentElement;
            return Math.max(
              body ? body.scrollHeight : 0,
              body ? body.offsetHeight : 0,
              html ? html.scrollHeight : 0,
              html ? html.offsetHeight : 0,
              html ? html.clientHeight : 0
            );
          } catch (_) {
            return null;
          }
        };

        const syncHeight = () => {
          const measured = measureFromIframe();
          if (measured && Number.isFinite(measured)) setHeight(measured);
        };

        const requestHeight = () => {
          try {
            iframe.contentWindow?.postMessage(
              { type: "hateful-eight:request-height" },
              window.location.origin
            );
          } catch (_) {}
        };

        setHeight(minHeight);

        window.addEventListener("message", (event) => {
          if (event.origin !== window.location.origin) return;
          if (event.source !== iframe.contentWindow) return;
          if (event.data?.type !== "hateful-eight:height") return;
          setHeight(event.data.height);
        });

        iframe.addEventListener("load", () => {
          syncHeight();
          requestHeight();
          [120, 320, 700, 1200, 2000, 3200].forEach((delay) => {
            setTimeout(() => {
              syncHeight();
              requestHeight();
            }, delay);
          });
          if (resizeTimer) clearInterval(resizeTimer);
          resizeTimer = setInterval(() => {
            syncHeight();
            requestHeight();
          }, 2000);
          setTimeout(() => {
            if (resizeTimer) clearInterval(resizeTimer);
            resizeTimer = null;
          }, 30000);
        });

        window.addEventListener("resize", () => {
          syncHeight();
          requestHeight();
        });
      })();
    </script>
  {{else}}
    <article class="post ghost-content prose md:prose-lg prose-theme">
      {{> pro-cta}}
    </article>
  {{/if}}
{{/page}}
